{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "esnext", // 决定编译后 JS 代码的[语法版本]; 例如: const,箭头函数等
    "module": "nodenext", // 决定编译后 JS 代码的 [模块系统格式]; nodenext同时兼容 CommonJS 和 ESModule
    "moduleResolution": "nodenext", // 决定 TS 编译器[如何找到import模块] bundler 无需.js后缀名称,需要配置 `tsc-alias` 在build后补全 .js 后缀
    // "outDir": "dist", // 必须在当前项目中设置; 输出目录
    // "rootDir": "src", // 必须在当前项目中设置;
    "strict": true, // 严格检查类型错误
    "declaration": true, // 生成 .d.ts 类型声明文件
    "esModuleInterop": true, // 兼容 CommonJS 语法的三方库
    "forceConsistentCasingInFileNames": true, // 强制文件名大小写一致
    "skipLibCheck": true // 跳过三方库类型检查，提高编译速度
  }
  // "tsc-alias": { "verbose": true, "resolveFullPaths": true } // 必须在当前项目中设置
  // "include": ["src/**/*"], // 必须在当前项目中设置
  // "exclude": ["node_modules", "src/**/*.test.ts"] // 必须在当前项目中设置
}
